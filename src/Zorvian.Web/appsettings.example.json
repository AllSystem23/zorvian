{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "NexoraDb": "Host=<your-host>;Database=<your-db>;Username=<your-user>;Password=<your-pass>;SSL Mode=Require;Trust Server Certificate=true"
    },
    "Jwt": {
        "Secret": "YOUR_SUPER_SECRET_KEY_AT_LEAST_32_CHARS",
        "ExpirationMinutes": "60",
        "RefreshExpirationDays": "7"
    },
    "Firebase": {
        "ProjectId": "nexora-hr",
        "CredentialsFilePath": "",
        "WebApiKey": "YOUR_FIREBASE_WEB_API_KEY"
    },
    "Cors": {
        "AllowedOrigins": [
            "http://localhost:3000",
            "http://localhost:5000",
            "https://app.nexora.app",
            "https://nexora-hr.web.app",
            "https://nexora-hr.firebaseapp.com"
        ]
    }
}